{
  "api_endpoint": "/api/v1/auth/login",
  "method": "POST",
  "description": "使用者登入驗證並獲取存取權杖 (Access Token)",
  "request": {
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "id": "string (required) - 使用者id",
      "password": "string (required) - 密碼"
    }
  },
  "responses": {
    "200_success": {
      "description": "登入成功",
      "body": {
        "status": "success",
        "data": {
          "token": "def502005a7b212f4533fd0a1...",
          "user": {
            "id": "113703000",
            "name": "michael_c",
            "role": "student"
          }
        }
      }
    },
    "400_Bad request": {
      "description": "請求格式錯誤或缺少必要欄位",
      "body": {
        "status": "error",
        "error": {
          "code": "VALIDATION_ERROR",
          "message": "缺少必要欄位：password"
        }
      }
    },
    "401_Unauthorized": {
      "description": "憑證無效或密碼錯誤",
      "body": {
        "status": "error",
        "error": {
          "code": "AUTH_INVALID_CREDENTIALS",
          "message": "使用者名稱或密碼錯誤",
          "remaining_attempts": 4
        }
      }
    },
    "403_forbidden": {
      "description": "帳號被鎖定或拒絕存取",
      "body": {
        "status": "error",
        "error": {
          "code": "AUTH_ACCOUNT_LOCKED",
          "message": "登入失敗次數過多，帳號已鎖定，請於 15 分鐘後再試。"
        }
      }
    }
  }
}