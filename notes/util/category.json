{
  "api_endpoint": "/api/v1/graduation/categories/{category_id}",
  "method": "GET",
  "description": "取得特定學分區塊的詳細進度與課程清單（用於點擊 Block 後跳轉的新頁面）",
  "request": {
    "headers": {
      "Authorization": "string (required) - Bearer Token，例如: Bearer eyJhbG..."
    },
    "path_parameters": {
      "category_id": "string (required) - 類別 ID，例如 'major_core', 'general_edu'"
    }
  },
  "responses": {
    "200_success": {
      "body": {
        "status": "success",
        "data": {
          "id": "major_department",
          "courses": [
            {
              "course_id": "CS101",
              "course_name": "資料結構",
              "course_type": "R",
              "teacher_name": "陳大文",
              "department_id": "703",
              "credits": 3,
              "grade": "A+",
              "semester": "112-1",
              "status": "passed"
            },
            {
              "course_id": "CS201",
              "course_name": "演算法",
              "course_type": "R",
              "teacher_name": "陳大文",
              "department_id": "703",
              "credits": 3,
              "grade": "A",
              "semester": "112-2",
              "status": "passed"
            }
          ]
        }
      }
    },
    "404_not_found": {
      "description": "找不到對應的學分類別",
      "body": {
        "status": "error",
        "error": {
          "code": "Category Not Found",
          "message": "無效的類別 ID"
        }
      }
    }
  }
}