{
  "api_endpoint": "/api/v1/teacher/students/credit-progress",
  "method": "GET",
  "description": "取得學生總體學分進度列表，支援多維度篩選與分頁。",
  "request": {
    "headers": {
      "Authorization": "string (required) - Bearer Token，例如: Bearer eyJhbG..."
    },
    "body": {
      "enrollment_year": "string (optional) - 入學年度，例如: '113'",
      "department_id": "string (optional) - 科系代碼，例如: '703'",
      "page": "integer (optional) - 頁碼，預設為 1",
      "limit": "integer (optional) - 每頁筆數，預設為 20"
    }
  },
  "responses": {
    "200_success": {
      "description": "成功取得學生列表與學分總覽資料",
      "body": {
        "status": "success",
        "meta": {
          "current_page": 1,
          "total_pages": 5,
          "total_count": 98,
          "limit": 20
        },
        "data": [
          {
            "student_info": {
              "student_id": "113000000",
              "name": "Yoga",
              "major1": "資訊科學系",
              "major2": null,
              "auxiliary1": null,
              "auxiliary2": null,
              "is_pass": true
            },
            "total_credits": {
              "earned": 129,
              "required": 128
            },
            "categories": [
              {
                "id": "major1",
                "name": "主修",
                "earned": 65,
                "required": 65,
                "hint": "尚缺xx 課程"
              },
              {
                "id": "out_department",
                "name": "外系選修",
                "earned": 26,
                "required": 28,
                "hint": "尚缺xx 課程"
              },
              {
                "id": "general_edu",
                "name": "通識課程",
                "earned": 26,
                "required": 28,
                "hint": "尚缺xx 課程"
              },
              {
                "id": "common_compulsory",
                "name": "共同必修",
                "earned": 12,
                "required": 7,
                "hint": "已超出必修學分，建議選修其他類別課程"
              },
              {
                "id": "major2",
                "name": "雙主修",
                "earned": 65,
                "required": 65,
                "hint": "尚缺xx 課程"
              },
              {
                "id": "auxiliary1",
                "name": "輔系",
                "earned": 65,
                "required": 65,
                "hint": "尚缺xx 課程"
              },
              {
                "id": "auxiliary2",
                "name": "輔系",
                "earned": 65,
                "required": 65,
                "hint": "尚缺xx 課程"
              }
            ]
          }
        ]
      }
    },
    "401_Unauthorized": {
      "description": "未提供 Token 或 Token 已失效",
      "body": {
        "status": "error",
        "error": {
          "code": "Unauthorized",
          "message": "請先登入系統"
        }
      }
    },
    "500_internal_server_error": {
      "description": "伺服器內部錯誤",
      "body": {
        "status": "error",
        "error": {
          "code": "INTERNAL_SERVER_ERROR",
          "message": "系統發生非預期錯誤，請稍後再試"
        }
      }
    }
  }
}