{
  "api_endpoint": "/api/v1/teacher/students/credit-progress",
  "method": "GET",
  "description": "取得學生總體學分進度列表，支援多維度篩選與分頁。",
  "request": {
    "headers": {
      "Authorization": "string (required) - Bearer Token，例如: Bearer eyJhbG..."
    },
    "body": {
      "enrollment_year": "string (optional) - 入學年度，例如: '113'",
      "department_id": "string (optional) - 科系代碼，例如: '703'",
      "category_id": "string (optional) - 學分類型篩選，例如: 'general_edu' (只列出該類別的進度)",
      "is_pass": "boolean (optional) - 篩選是否達標，例如: true (已達標), false (未達標)",
      "page": "integer (optional) - 頁碼，預設為 1",
      "limit": "integer (optional) - 每頁筆數，預設為 20"
    }
  },
  "responses": {
    "200_success": {
      "description": "成功取得學生列表與學分總覽資料",
      "body": {
        "status": "success",
        "meta": {
          "current_page": 1,
          "total_pages": 5,
          "total_count": 98,
          "limit": 20
        },
        "data": [
          {
            "student_info": {
              "student_id": "113000000",
              "name": "Yoga",
              "major1": "資訊科學系",
              "major2": null,
              "auxiliary": null,
              "is_pass": true
            },
            "total_credits": {
              "earned": 129,
              "required": 128
            }
          }
        ]
      }
    },
    "401_Unauthorized": {
      "description": "未提供 Token 或 Token 已失效",
      "body": {
        "status": "error",
        "error": {
          "code": "Unauthorized",
          "message": "請先登入系統"
        }
      }
    },
    "500_internal_server_error": {
      "description": "伺服器內部錯誤",
      "body": {
        "status": "error",
        "error": {
          "code": "INTERNAL_SERVER_ERROR",
          "message": "系統發生非預期錯誤，請稍後再試"
        }
      }
    }
  }
}